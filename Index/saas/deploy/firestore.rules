// ================================================================
// firestore.rules — Regras de Segurança Firestore
// Projeto: banco-de-dados-julio
// ================================================================
//
// COMO PUBLICAR:
//   firebase deploy --only firestore:rules
//
// Ou cole diretamente no Firebase Console:
//   https://console.firebase.google.com/project/banco-de-dados-julio/firestore/rules
// ================================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser() {
      return isAuthenticated()
        && request.auth.token.email_verified == true;
    }

    function notTooLarge(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ── /users/{userId} — dados do perfil ───────────────────────────
    match /users/{userId} {
      // Leitura: somente o próprio usuário
      allow read: if isOwner(userId);

      // Escrita: somente o próprio usuário, com campos permitidos
      allow create, update: if isOwner(userId)
        && notTooLarge(['displayName', 'email', 'photoURL', 'createdAt', 'updatedAt', 'preferences'])
        && request.resource.data.email == request.auth.token.email;

      // Delete: somente o próprio usuário
      allow delete: if isOwner(userId);
    }

    // ── /users/{userId}/private/{doc} — dados sensíveis ─────────────
    match /users/{userId}/private/{document} {
      allow read, write: if isOwner(userId) && isValidUser();
    }

    // ── /activity/{docId} — log de atividade ────────────────────────
    match /activity/{docId} {
      // Usuário só pode ler sua própria atividade
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;

      // Escrita com campos obrigatórios
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'type', 'message', 'timestamp'])
        && request.resource.data.timestamp == request.time;

      // Sem atualização ou delete pelo cliente
      allow update, delete: if false;
    }

    // ── /settings/{userId} — preferências ───────────────────────────
    match /settings/{userId} {
      allow read, write: if isOwner(userId)
        && notTooLarge(['theme', 'language', 'notifications', 'updatedAt']);
    }

    // ── Bloqueio total por padrão ────────────────────────────────────
    // Qualquer coleção não listada acima é bloqueada
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
